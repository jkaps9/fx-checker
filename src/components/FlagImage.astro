---
import type { ImageMetadata } from "astro";
import Image from "astro/components/Image.astro";

interface Props {
  countryCode: string;
}
const { countryCode } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/flags/*.webp",
);

const imagePath = `/src/assets/images/flags/${countryCode.toLowerCase()}.webp`;
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "/src/assets/images/flags/*.webp"`,
  );
---

<Image
  src={images[imagePath]()}
  alt=`${countryCode} flag`
  class="flag"
/>

<style lang="scss" is:global>
  .flag {
    block-size: 1.25rem;
    border-radius: 50%;
    flex-shrink: 0;
    inline-size: 1.25rem;
    object-fit: cover;
  }
</style>
