---
interface Props {
  countryCode: string;
}
const { countryCode } = Astro.props;
---

<img
  class="flag"
  src=`/fx-checker/images/flags/${countryCode}.webp`
  alt=`${countryCode} flag`
/>

<style lang="scss" is:global>
  .flag {
    block-size: 1.25rem;
    border-radius: 50%;
    flex-shrink: 0;
    inline-size: 1.25rem;
    object-fit: cover;
  }
</style>
