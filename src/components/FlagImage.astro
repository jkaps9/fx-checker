---
import { getCountryName } from "@lib/generalUtils";
interface Props {
  countryCode: string;
}

const { countryCode } = Astro.props;
const countryName = getCountryName(countryCode);
---

<img
  class="flag"
  src=`/fx-checker/images/flags/${countryCode}.webp`
  alt=`${countryName} flag`
/>

<style lang="scss" is:global>
  .flag {
    block-size: 1.25rem;
    border-radius: 50%;
    flex-shrink: 0;
    inline-size: 1.25rem;
    object-fit: cover;
  }
</style>
