---
import { Icon } from "astro-icon/components";
import currencies from "@data/currencies.json";
import CurrencyOption from "./CurrencyOption.astro";
const { defaultBase = "USD", defaultTarget = "EUR" } = Astro.props;
---

<section class="input">
  <div class="container">
    <h2>Check the Rate</h2>
    <div class="card">
      <form id="fx-input">
        <div class="form-group card--inner">
          <label for="base-amount"><h3>Send</h3></label>
          <div class="input-row">
            <input
              type="number"
              id="base-amount"
              name="base-amount"
              placeholder="0"
            />
            <select
              name="base"
              id="base-currency"
            >
              <button class="select-button">
                <selectedcontent></selectedcontent>
              </button>
              <optgroup label="POPULAR">
                {
                  currencies
                    .filter((c) => c.popular)
                    .map((currency) => (
                      <CurrencyOption
                        currencyCode={currency.iso_code}
                        currencyName={currency.name}
                        defaultCode={defaultBase}
                      />
                    ))
                }
              </optgroup>
              <optgroup label="OTHER CURRENCIES">
                {
                  currencies
                    .filter((c) => !c.popular)
                    .map((currency) => (
                      <CurrencyOption
                        currencyCode={currency.iso_code}
                        currencyName={currency.name}
                        defaultCode={defaultBase}
                      />
                    ))
                }
              </optgroup>
            </select>
          </div>
        </div>
        <button
          class="currency-swap"
          id="currency-swap"
          type="button"
          aria-label="switch currencies"
        >
          <Icon
            name="icon-exchange-vertical"
            aria-hidden="true"
          />
        </button>
        <div class="form-group card--inner">
          <label for="output-amount"><h3>Receive</h3></label>
          <div class="input-row">
            <output
              id="output-amount"
              name="output-amount"
              for="base-amount base-currency target-currency"
            >
              0
            </output>
            <select
              name="target"
              id="target-currency"
            >
              <button class="select-button">
                <selectedcontent></selectedcontent>
              </button>
              <optgroup label="POPULAR">
                {
                  currencies
                    .filter((c) => c.popular)
                    .map((currency) => (
                      <CurrencyOption
                        currencyCode={currency.iso_code}
                        currencyName={currency.name}
                        defaultCode={defaultTarget}
                      />
                    ))
                }
              </optgroup>
              <optgroup label="OTHER CURRENCIES">
                {
                  currencies
                    .filter((c) => !c.popular)
                    .map((currency) => (
                      <CurrencyOption
                        currencyCode={currency.iso_code}
                        currencyName={currency.name}
                        defaultCode={defaultTarget}
                      />
                    ))
                }
              </optgroup>
            </select>
          </div>
        </div>
      </form>
      <div class="bottom-row">
        <p id="output">1 USD = 0.8530 EUR</p>
        <div class="buttons">
          <button
            type="button"
            class="btn btn--primary"
            id="favorite-button"
          >
            Favorite
          </button>
          <button
            type="button"
            class="btn btn--primary"
          >
            Log Conversion
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

