<style lang="scss">
  label {
    display: block;
    margin-bottom: 1.25rem;
  }

  input {
    background: none;
    color: inherit;
    font-family: inherit;
    border: none;
    outline: none;
    width: 100%;
  }

  select {
    background-color: #2e2e2e;
    color: var(--color-body-text-light);
    cursor: pointer;
    place-items: center;

    &,
    &::picker(select) {
      appearance: base-select;
    }

    &::picker-icon {
      transition: transform 0.3s;
    }

    &:open {
      &::picker-icon {
        transform: rotate(180deg);
      }
    }
  }

  .select-button {
    align-items: center;
    block-size: 2.5rem;
    display: flex;
    inline-size: 100%;
  }

  selectedcontent {
    align-items: center;
    display: flex;
    gap: var(--space-sm);
  }

  :global(selectedcontent > span.currency-name) {
    display: none;
  }

  form {
    display: grid;
    gap: clamp(var(--space-md), 0.8239rem + 0.7512vw, var(--space-lg));
    padding-bottom: clamp(
      var(--space-md),
      0.912rem + 0.3756vw,
      calc(var(--space-md) * 1.25)
    );
    @include bp(md) {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
    }
  }

  .card {
    display: grid;
    padding: clamp(
      var(--space-md),
      0.912rem + 0.3756vw,
      calc(var(--space-md) * 1.25)
    );
  }

  .currency-swap {
    align-items: center;
    background: #202022;
    border: 1px solid #2e2e2e;
    border-radius: var(--radius-8);
    display: flex;
    justify-content: center;
    margin: auto;
    min-height: 3rem;
    min-width: 3rem;

    &:hover {
      background: #2e2e2e;
    }

    @include bp(md) {
      transform: rotate(90deg);
    }
  }

  .form-group {
    display: grid;
    padding: clamp(
      var(--space-md),
      0.912rem + 0.3756vw,
      calc(var(--space-md) * 1.25)
    );
  }

  optgroup {
    background-color: #202022;
    color: #9d9d9d;
    font-size: 12px;
    margin: 0;
    padding: 0;
    &:first-of-type {
      padding-block-start: var(--space-xs);
    }
    &:not(:last-of-type) {
      padding-block-end: var(--space-xs);
    }
  }

  .input-row {
    @include flex-between;
    flex: 1;
  }

  .bottom-row {
    @include flex-between;
  }
</style>
