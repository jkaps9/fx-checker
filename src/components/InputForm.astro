---
import { Icon } from "astro-icon/components";
import currencies from "@data/currencies.json";
import CurrencyOption from "./CurrencyOption.astro";
import CustomSelect from "./CustomSelect.astro";
const { defaultBase = "USD", defaultTarget = "EUR" } = Astro.props;
---

<section class="input">
  <div class="container">
    <h2>Check the Rate</h2>
    <div class="card">
      <form id="fx-input">
        <div class="form-group card--inner">
          <label for="base-amount"><h3>Send</h3></label>
          <div class="input-row">
            <input
              type="text"
              id="base-amount"
              inputmode="numeric"
              name="base-amount"
              placeholder="0"
            />
            <CustomSelect defaultCurrency={defaultBase} />
          </div>
        </div>
        <button
          class="currency-swap"
          id="currency-swap"
          type="button"
          aria-label="switch currencies"
        >
          <Icon
            name="icon-exchange-vertical"
            aria-hidden="true"
          />
        </button>
        <div class="form-group card--inner">
          <label for="output-amount"><h3>Receive</h3></label>
          <div class="input-row">
            <output
              id="output-amount"
              name="output-amount"
              for="base-amount base-currency target-currency"
            >
              0
            </output>
            <CustomSelect defaultCurrency={defaultTarget} />
          </div>
        </div>
      </form>
      <div class="bottom-row">
        <p id="output">1 USD = 0.8530 EUR</p>
        <div class="buttons">
          <button
            type="button"
            class="btn"
            id="favorite-button"
          >
            <Icon
              name="icon-star"
              aria-hidden="true"
              height={16}
              width={16}
            />
            <Icon
              name="icon-star-filled"
              aria-hidden="true"
              height={16}
              width={16}
            />
            <span class="text">Favorite</span>
          </button>
          <button
            type="button"
            class="btn"
            id="log-conversion"
          >
            <Icon
              name="icon-check"
              aria-hidden="true"
              height={16}
              width={16}
            />
            <span class="base">Log Conversion</span>
            <span class="logged">Logged</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  section {
    padding-top: clamp(2rem, 1.6479rem + 1.5023vw, 3rem);
  }
  .card {
    padding: 0;
  }
  .container {
    display: grid;
    gap: 1rem;
  }
  label {
    display: block;
    margin-bottom: 1.25rem;
  }

  input {
    background: none;
    font-family: inherit;
    border: none;
    outline: none;
    width: 100%;
  }

  select {
    background-color: var(--color-border);

    &:hover {
      background-color: var(--color-background-hover);
    }
  }

  :global(selectedcontent > span.currency-name) {
    display: none;
  }

  form {
    display: grid;
    gap: clamp(var(--space-md), 0.8239rem + 0.7512vw, var(--space-lg));
    padding-block: clamp(
      var(--space-md),
      0.912rem + 0.3756vw,
      calc(var(--space-md) * 1.25)
    );
    padding-inline: clamp(
      var(--space-md),
      0.912rem + 0.3756vw,
      calc(var(--space-md) * 1.25)
    );

    @include bp(md) {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
    }
  }

  .currency-swap {
    align-items: center;
    background: var(--color-background-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-8);
    display: flex;
    justify-content: center;
    margin: auto;
    min-height: 3rem;
    min-width: 3rem;

    &:hover {
      background: var(--color-border);
    }

    @include bp(md) {
      transform: rotate(90deg);
    }
  }

  .form-group {
    display: grid;
    padding: clamp(
      var(--space-md),
      0.912rem + 0.3756vw,
      calc(var(--space-md) * 1.25)
    );
  }

  optgroup {
    background-color: var(--color-background-surface);
    color: var(--color-body-text-muted);
    font-size: 12px;
    margin: 0;
    padding: 0;
    &:first-of-type {
      padding-block-start: var(--space-xs);
    }
    &:not(:last-of-type) {
      padding-block-end: var(--space-xs);
    }
  }

  .input-row {
    @include flex-between;
    flex: 1;
  }

  .bottom-row {
    @include flex-between;
    border-top: 1px dashed var(--color-border);
    flex-direction: column;
    gap: 1rem;
    padding-block: 1rem;
    padding-inline: clamp(
      var(--space-md),
      0.912rem + 0.3756vw,
      calc(var(--space-md) * 1.25)
    );

    @include bp(md) {
      flex-direction: row;
    }
  }

  #log-conversion {
    align-items: center;
    border: 1px solid var(--color-primary);
    color: var(--color-body-text);
    justify-content: center;
    min-width: 135px;
    text-align: center;
  }

  .buttons {
    display: flex;
    gap: 0.75rem;
  }

  .btn {
    align-items: center;
    gap: 0.5rem;
  }

  .logged {
    display: none;
  }

  [data-icon="icon-star-filled"] {
    color: var(--color-text-on-primary);
    display: none;
  }

  [data-icon="icon-star"] {
    display: block;
  }

  [data-icon="icon-check"] {
    display: none;
  }

  .active {
    .logged {
      display: block;
    }
    .base {
      display: none;
    }
    [data-icon="icon-star"] {
      display: none;
    }
    [data-icon="icon-check"],
    [data-icon="icon-star-filled"] {
      display: block;
    }
  }

  #output {
    font-size: clamp(0.625rem, 0.581rem + 0.1878vw, 0.75rem);
  }
</style>
