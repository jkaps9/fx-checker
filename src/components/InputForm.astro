---
import { Icon } from "astro-icon/components";
import currencies from "@data/currencies.json";
import CurrencyOption from "./CurrencyOption.astro";
const { defaultBase = "USD", defaultTarget = "EUR" } = Astro.props;
---

<section class="input">
  <div class="container">
    <h2>Check the Rate</h2>
    <div class="card">
      <form id="fx-input">
        <div class="form-group card--inner">
          <label for="base-amount"><h3>Send</h3></label>
          <div class="input-row">
            <input
              type="text"
              id="base-amount"
              inputmode="numeric"
              name="base-amount"
              placeholder="0"
            />
            <select
              name="base"
              id="base-currency"
            >
              <button class="select-button">
                <selectedcontent></selectedcontent>
              </button>
              <optgroup label="POPULAR">
                {
                  currencies
                    .filter((c) => c.popular)
                    .map((currency) => (
                      <CurrencyOption
                        currencyCode={currency.iso_code}
                        currencyName={currency.name}
                        defaultCode={defaultBase}
                      />
                    ))
                }
              </optgroup>
              <optgroup label="OTHER CURRENCIES">
                {
                  currencies
                    .filter((c) => !c.popular)
                    .map((currency) => (
                      <CurrencyOption
                        currencyCode={currency.iso_code}
                        currencyName={currency.name}
                        defaultCode={defaultBase}
                      />
                    ))
                }
              </optgroup>
            </select>
          </div>
        </div>
        <button
          class="currency-swap"
          id="currency-swap"
          type="button"
          aria-label="switch currencies"
        >
          <Icon
            name="icon-exchange-vertical"
            aria-hidden="true"
          />
        </button>
        <div class="form-group card--inner">
          <label for="output-amount"><h3>Receive</h3></label>
          <div class="input-row">
            <output
              id="output-amount"
              name="output-amount"
              for="base-amount base-currency target-currency"
            >
              0
            </output>
            <select
              name="target"
              id="target-currency"
            >
              <button class="select-button">
                <selectedcontent></selectedcontent>
              </button>
              <optgroup label="POPULAR">
                {
                  currencies
                    .filter((c) => c.popular)
                    .map((currency) => (
                      <CurrencyOption
                        currencyCode={currency.iso_code}
                        currencyName={currency.name}
                        defaultCode={defaultTarget}
                      />
                    ))
                }
              </optgroup>
              <optgroup label="OTHER CURRENCIES">
                {
                  currencies
                    .filter((c) => !c.popular)
                    .map((currency) => (
                      <CurrencyOption
                        currencyCode={currency.iso_code}
                        currencyName={currency.name}
                        defaultCode={defaultTarget}
                      />
                    ))
                }
              </optgroup>
            </select>
          </div>
        </div>
      </form>
      <div class="bottom-row">
        <p id="output">1 USD = 0.8530 EUR</p>
        <div class="buttons">
          <button
            type="button"
            class="btn"
            id="favorite-button"
          >
            <Icon
              name="icon-star"
              aria-hidden="true"
              height={16}
              width={16}
            />
            <Icon
              name="icon-star-filled"
              aria-hidden="true"
              height={16}
              width={16}
            />
            <span class="text">Favorite</span>
          </button>
          <button
            type="button"
            class="btn"
            id="log-conversion"
          >
            Log Conversion
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .card {
    padding: 0;
  }
  .container {
    display: grid;
    gap: 1rem;
  }
  label {
    display: block;
    margin-bottom: 1.25rem;
  }

  input {
    background: none;
    font-family: inherit;
    border: none;
    outline: none;
    width: 100%;
  }

  select {
    background-color: var(--color-border);
    border: 1px solid var(--color-background-hover);
    color: var(--color-body-text-light);
    cursor: pointer;
    place-items: center;

    &,
    &::picker(select) {
      appearance: base-select;
    }

    &::picker-icon {
      transition: transform 0.3s;
    }

    &:open {
      &::picker-icon {
        transform: rotate(180deg);
      }
    }

    &:hover {
      background-color: var(--color-background-hover);
    }
  }

  .select-button {
    align-items: center;
    block-size: 2.5rem;
    display: flex;
    inline-size: 100%;
  }

  selectedcontent {
    align-items: center;
    display: flex;
    gap: var(--space-sm);
  }

  :global(selectedcontent > span.currency-name) {
    display: none;
  }

  form {
    display: grid;
    gap: clamp(var(--space-md), 0.8239rem + 0.7512vw, var(--space-lg));
    padding-block: clamp(
      var(--space-md),
      0.912rem + 0.3756vw,
      calc(var(--space-md) * 1.25)
    );
    padding-inline: clamp(
      var(--space-md),
      0.912rem + 0.3756vw,
      calc(var(--space-md) * 1.25)
    );

    @include bp(md) {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
    }
  }

  .currency-swap {
    align-items: center;
    background: var(--color-background-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-8);
    display: flex;
    justify-content: center;
    margin: auto;
    min-height: 3rem;
    min-width: 3rem;

    &:hover {
      background: var(--color-border);
    }

    @include bp(md) {
      transform: rotate(90deg);
    }
  }

  .form-group {
    display: grid;
    padding: clamp(
      var(--space-md),
      0.912rem + 0.3756vw,
      calc(var(--space-md) * 1.25)
    );
  }

  optgroup {
    background-color: var(--color-background-surface);
    color: var(--color-body-text-muted);
    font-size: 12px;
    margin: 0;
    padding: 0;
    &:first-of-type {
      padding-block-start: var(--space-xs);
    }
    &:not(:last-of-type) {
      padding-block-end: var(--space-xs);
    }
  }

  .input-row {
    @include flex-between;
    flex: 1;
  }

  .bottom-row {
    @include flex-between;
    border-top: 1px dashed var(--color-border);
    padding-block: 1rem;
    padding-inline: clamp(
      var(--space-md),
      0.912rem + 0.3756vw,
      calc(var(--space-md) * 1.25)
    );
  }

  #log-conversion {
    border: 1px solid var(--color-primary);
  }

  .buttons {
    display: flex;
    gap: 0.75rem;
  }

  .btn {
    align-items: center;
    gap: 0.5rem;
  }

  [data-icon="icon-star-filled"] {
    color: var(--color-text-on-primary);
    display: none;
  }

  [data-icon="icon-star"] {
    display: block;
  }

  .active {
    [data-icon="icon-star"] {
      display: none;
    }
    [data-icon="icon-star-filled"] {
      display: block;
    }
  }
</style>
