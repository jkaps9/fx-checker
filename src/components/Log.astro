---

---

<section
  class="log"
  id="log"
>
  <div class="container">
    <div class="card">
      <div class="top-row">
        <h2>Conversion Log</h2>
        <div class="top-row__right-side">
          <p><span id="num-logged">0</span> Logged</p>
          <button
            type="button"
            class="btn"
            id="clear-log"
          >
            Clear All
          </button>
        </div>
      </div>
      <ul class="log__list"></ul>
    </div>
  </div>
</section>

<style lang="scss">
  .top-row {
    @include flex-between;
  }
  .log__list {
    display: grid;
    gap: 0.75rem;
    margin-block-start: 1.25rem;
  }
</style>
<style lang="scss" is:global>
  .log__item {
    @include flex-between;
  }

  .log-item {
    &__currency-pair {
      display: flex;
      gap: var(--space-sm);
    }
    &__right-side {
      .right-side__content {
        @include flex-center;
        gap: calc(var(--space-md) * 1.25);
        text-align: end;
      }
    }
  }
</style>
