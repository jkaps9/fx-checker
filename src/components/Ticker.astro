---

---

<section class="ticker">
  <div class="title">
    <div class="divider"></div>
    <h2>Live Markets</h2>
  </div>
  <div class="list-container">
    <ul class="ticker__list"></ul>
  </div>
</section>

<style lang="scss">
  .ticker {
    align-items: center;
    display: flex;
    padding-block: 0;
  }

  .title {
    align-items: center;
    background-color: var(--color-primary);
    display: flex;
    gap: var(--space-sm);
    place-content: center;
    height: stretch;
    padding: calc(var(--space-sm) * 1.5) var(--space-md);

    h2 {
      color: var(--color-text-on-primary);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.5px;
      line-height: 1.3;
      text-wrap: nowrap;
    }
  }

  .list-container {
    overflow: hidden;
    white-space: nowrap;
  }

  .ticker__list {
    animation: scroll-left 300s infinite linear;
    background: var(--color-background-surface);
    display: flex;
    width: max-content;
  }

  :global(.ticker__list > li) {
    background: var(--color-background-surface);
    border-right: 1px solid var(--color-border);
    display: flex;
    font-size: 12px;
    gap: calc(var(--space-sm) + 2px);
    padding: calc(var(--space-sm) * 1.5);
  }

  @keyframes scroll-left {
    from {
      transform: translateX(0%);
    }
    to {
      transform: translateX(-100%);
    }
  }
</style>
