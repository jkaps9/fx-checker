---

<section class="ticker">
  <div class="container">
    <h2>Live Markets</h2>
    <ul class="ticker__list"></ul>
  </div>
</section>

<script>
  import { FrankfurterAPI } from "@lib/frankfurter_api";
  import currencies from "@data/currencies.json";

  const popularCurrencies = currencies.filter((c) => c.popular);
  const frankfurterAPI = new FrankfurterAPI();
  const tickerList = document.querySelector(".ticker__list") as HTMLElement;
  async function getRates(currency: string) {
    if (!currency || currency === "" || currency.length !== 3) return;
    try {
      const data = await frankfurterAPI.fetchAllRates(currency);
      const listItems = data.map((n) => {
        const item = document.createElement("li");
        const currencyPair = document.createElement("span");
        currencyPair.className = "currency-pair";
        currencyPair.textContent = `${n.base}/${n.quote}`;
        const currencyRate = document.createElement("span");
        currencyRate.className = "rate";
        currencyRate.textContent = `${n.rate}`;
        item.appendChild(currencyPair);
        item.appendChild(currencyRate);
        return item;
      });

      listItems.forEach((item) => tickerList.appendChild(item));
    } catch (error) {
      console.error(error);
    }
  }

  popularCurrencies.forEach((currency) => getRates(currency.iso_code));
</script>

<style lang="scss">
  .container {
    align-items: center;
    display: flex;
  }

  h2 {
    text-wrap: nowrap;
  }

  .ticker__list {
    display: flex;
    overflow: hidden;
  }

  :global(.ticker__list > li) {
    background: #202022;
    border-right: 1px solid #2e2e2e;
    display: flex;
    font-size: 12px;
    gap: calc(var(--space-sm) + 2px);
    padding: calc(var(--space-sm) * 1.5);
  }

  :global(.ticker__list > li > span.currency-pair) {
    color: #9d9d9d;
  }
</style>
