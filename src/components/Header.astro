---
import { Icon } from "astro-icon/components";
import currencies from "@data/currencies.json";

import ThemeSwitcher from "./ThemeSwitcher.astro";
---

<header>
  <div class="container">
    <h1 class="sr-only">FX Checker</h1>
    <Icon name="logo-small" />
    <Icon name="logo" />
    <div class="header__right">
      <p class="header__content muted-text">
        {currencies.length} CURRENCIES · EOD · ECB DATA
      </p>
      <ThemeSwitcher />
    </div>
  </div>
</header>

<style lang="scss">
  header {
    padding-block: clamp(1rem, 0.912rem + 0.3756vw, 1.25rem);
  }

  .container {
    @include flex-between;
  }

  .header__content {
    font-size: clamp(0.625rem, 0.3865rem + 1.0178vw, 0.875rem);
    letter-spacing: 1px;
    line-height: 1.2;
  }

  [data-icon="logo"] {
    @include bp-max(md) {
      display: none;
    }
    @include bp(md) {
      height: clamp(1.25rem, 0.8922rem + 1.5267vw, 1.625rem);
      width: auto;
    }
  }

  [data-icon="logo-small"] {
    @include bp-max(md) {
      height: 26px;
      width: 26px;
    }
    @include bp(md) {
      display: none;
    }
  }

  .header__right {
    @include flex-center;
    gap: 1em;
    text-align: center;
    p {
      line-height: 1.6;
    }
  }
</style>
