---
import FlagImage from "./FlagImage.astro";
---

<section
  class="compare"
  id="compare"
>
  <div class="container">
    <div
      class="card"
      id="compare-card"
    >
      <div class="top-row">
        <p>Multi-currency <span id="compare-amount">0.00 FROM USD</span></p>
        <p><span id="compare-pairs">8</span> PAIRS</p>
      </div>
      <ul id="comparison__list"></ul>
    </div>
    <div class="empty-section">
      <h2>No comparison available</h2>
      <p>
        Enter an amount in SEND above to see what your money is worth in other
        currencies.
      </p>
    </div>
  </div>
</section>

<style lang="scss">
  .top-row {
    @include flex-between;
  }
</style>

<style lang="scss" is:global>
  .flag {
    block-size: 1.5rem;
    inline-size: 1.5rem;
  }

  .comparison {
    &__item {
      @include flex-between;
    }
  }

  .left-side {
    display: flex;
  }
  .empty-section {
    @include flex-center;
    flex-direction: column;
    gap: 1rem;
    padding-block: 40px;
    text-align: center;
    h2 {
      color: #c6c6c6;
      text-transform: none;
    }
    p {
      color: #9d9d9d;
      font-size: 14px;
      line-height: 1.2;
      max-width: 50ch;
    }
  }
</style>
