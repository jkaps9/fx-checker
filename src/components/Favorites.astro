---

---

<section
  class="favorites"
  id="favorites"
>
  <div class="container">
    <div
      class="card"
      id="favorites-card"
    >
      <div class="card__top-row">
        <h2>Pinned Pairs</h2>
        <p><span id="num-favorites">0</span> FAVORITES</p>
      </div>
      <ul class="favorites__list"></ul>
    </div>
    <div class="empty-section">
      <h2>No pinned pairs yet</h2>
      <p>
        Pin a pair to track its rate here. Tap the star icon on any conversion
        or comparison row.
      </p>
    </div>
  </div>
</section>

<style lang="scss">
  .card__top-row {
    p {
      font-size: 12px;
      opacity: 0.7;
    }
  }
  .favorites__list {
    display: grid;
    gap: 0.75rem;
    margin-block-start: 1.25rem;
  }
</style>
<style lang="scss" is:global>
  .favorites__item {
    @include flex-between;
    &:hover {
      cursor: pointer;
    }
  }
  .favorites-item {
    &__currency-pair {
      display: flex;
      gap: var(--space-sm);
    }
    &__right-side {
      @include flex-center;
      gap: calc(var(--space-md) * 1.25);
      text-align: end;
      .percent-change {
        font-size: 10px;
        margin-top: 6px;
      }
    }
  }
</style>
