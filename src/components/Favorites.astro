---

---

<section
  class="favorites"
  id="favorites"
>
  <div class="container">
    <div class="card">
      <div class="top-row">
        <h2>Pinned Pairs</h2>
        <p><span id="num-favorites">0</span> FAVORITES</p>
      </div>
      <ul class="favorites__list"></ul>
    </div>
  </div>
</section>

<style lang="scss">
  .top-row {
    @include flex-between;
  }
  .favorites__list {
    display: grid;
    gap: 0.75rem;
    margin-block-start: 1.25rem;
  }
</style>
<style lang="scss" is:global>
  .favorites__item {
    @include flex-between;
  }
  .favorites-item {
    &__currency-pair {
      display: flex;
      gap: var(--space-sm);
    }
    &__right-side {
      @include flex-center;
      gap: calc(var(--space-md) * 1.25);
      text-align: end;
      .percent-change {
        font-size: 10px;
        margin-top: 6px;
      }
    }
  }
</style>
