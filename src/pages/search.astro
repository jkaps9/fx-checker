---
import { Icon } from "astro-icon/components";
import BaseLayout from "@layouts/BaseLayout.astro";
import currencies from "@data/currencies.json";
import CurrencyOption from "@components/CurrencyOption.astro";
import FlagImage from "@components/FlagImage.astro";

const { defaultBase = "USD", defaultTarget = "EUR" } = Astro.props;
---

<BaseLayout pageTitle="Search">
  <section>
    <div class="container">
      <div class="custom-select">
        <button
          class="select-button"
          type="button"
        >
          <div class="selected-content">
            <FlagImage countryCode="us" />
            <span class="currency-code">USD</span>
            <Icon
              name="icon-chevron-down"
              class="picker-icon"
            />
          </div>
        </button>

        <div class="dropdown-menu visually-hidden">
          <input
            type="text"
            class="input-search"
            placeholder="Search currencies..."
          />
          <ul class="currencies-list">
            <li class="currencies-list__label">POPULAR</li>
            {
              currencies
                .filter((c) => c.popular)
                .map((currency) => (
                  <CurrencyOption
                    currencyCode={currency.iso_code}
                    currencyName={currency.name}
                    defaultCode={defaultBase}
                  />
                ))
            }
            <li class="currencies-list__label">OTHER CURRENCIES</li>
            {
              currencies
                .filter((c) => !c.popular)
                .map((currency) => (
                  <CurrencyOption
                    currencyCode={currency.iso_code}
                    currencyName={currency.name}
                    defaultCode={defaultBase}
                  />
                ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<script>
  const selectButton = document.querySelector(
    ".select-button",
  ) as HTMLButtonElement;
  const dropDownMenu = document.querySelector(".dropdown-menu") as HTMLElement;
  selectButton.addEventListener("click", () => {
    dropDownMenu.classList.toggle("visually-hidden");
    selectButton.classList.toggle("open");
  });
</script>
<style lang="scss">
  .custom-select {
    position: relative;
    width: fit-content;
  }
  .selected-content {
    align-items: center;
    display: flex;
    gap: var(--space-sm);
  }

  .dropdown-menu {
    left: 0;
    position: absolute;
    top: 100%;
    width: fit-content;
    z-index: 900;
  }
</style>
